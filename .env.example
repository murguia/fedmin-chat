# OpenAI API key for embeddings and LLM responses
OPENAI_API_KEY=sk-...

# Pinecone API key for vector database
PINECONE_API_KEY=...

# Pinecone index name (default: fedmin-chat)
PINECONE_INDEX_NAME=fedmin-chat

# LangSmith tracing (optional). When LANGSMITH_TRACING=true and an API key is
# set, the agent loop, retrieval, and reranking are traced to LangSmith. Leave
# unset to disable — the app and eval run normally without it.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=fedmin-chat
